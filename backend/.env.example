# Server Configuration
SERVER_PORT=8080
GIN_MODE=debug

# Database Configuration
DB_DRIVER=sqlite
DB_DSN=token-hub.db

# JWT Configuration
JWT_SECRET=token-hub-secret-key-2024-change-this-in-production
JWT_EXPIRE_TIME=86400

# Points Configuration
POINTS_RATE=100

# Alipay Configuration
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY=your_alipay_private_key
ALIPAY_PUBLIC_KEY=your_alipay_public_key
ALIPAY_NOTIFY_URL=http://localhost:8080/api/v1/payment/alipay/notify
ALIPAY_RETURN_URL=http://localhost:8080/api/v1/payment/alipay/return
ALIPAY_SANDBOX=true

# Wechat Payment Configuration
WECHAT_APP_ID=your_wechat_app_id
WECHAT_MCH_ID=your_wechat_mch_id
WECHAT_API_KEY=your_wechat_api_key
WECHAT_NOTIFY_URL=http://localhost:8080/api/v1/payment/wechat/notify
WECHAT_CERT_PATH=./certs/apiclient_cert.pem
WECHAT_KEY_PATH=./certs/apiclient_key.pem
